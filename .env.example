# Socialium Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control!

# Application
APP_NAME=Socialium
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=sqlite+aiosqlite:///./socialium.db
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Supabase Auth
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (OAuth token storage)
ENCRYPTION_KEY=your-encryption-key-32bytes!!

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Anthropic (Claude — quality scoring)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Groq (Fallback LLM)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# WhatsApp (WapiHub)
WAPIHUB_API_KEY=your_wapihub_api_key_here
WAPIHUB_URL=https://app.whapihub.com/api/v2/whatsapp-business
WAPIHUB_WEBHOOK_SECRET=your-wapihub-webhook-secret-here
WAPIHUB_PHONE_NUMBER_ID=your_wapihub_phone_number_id

# Qdrant (Vector DB)
QDRANT_URL=your_qdrant_cloud_url
QDRANT_API_KEY=your_qdrant_api_key_here

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/v1/oauth/linkedin/callback

# Twitter/X OAuth
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

# Instagram OAuth
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Stripe (Billing) - Optional
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ── Monitoring ──
# Langfuse (LLM observability)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+1234567890

# PostHog (product analytics)
POSTHOG_API_KEY=your_posthog_api_key
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_ID=your_posthog_project_id
POSTHOG_PERSONAL_API_KEY=your_posthog_personal_api_key

# Sentry (error tracking)
SENTRY_DSN=your_sentry_dsn_here
